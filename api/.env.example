# WardWatch API - Environment Variable Template
# NEVER put real values in this file.
# This file is committed to git as documentation only.
# Real values live in Google Cloud Secret Manager.

# Required: GCP Project ID (not a secret, safe to set as env var)
PROJECT_ID=wardwatch-2c4fd

# The following are SECRET names only - actual values are in Secret Manager
# Do NOT put real API keys here.
GEMINI_SECRET_NAME=gemini-api-key
SENDGRID_SECRET_NAME=sendgrid-api-key
MAPS_SECRET_NAME=maps-api-key
